# Security headers for Cloudflare Pages.
# Served on every route; static assets and the /api/feedback Function included.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), interest-cohort=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; img-src 'self' data:; style-src 'self' https://fonts.bunny.net; font-src https://fonts.bunny.net; script-src 'self' 'sha256-zYCRL2xS931BeMeTv0vqJATbQ/2zThkVsEhniOXNThc=' 'sha256-g1uVwcpauDD17Ayi/Fi9+fufCGMH8TJ5k++kpx2nRA8=' 'sha256-obcfgWn+P2iN7enQjQ8bAkpfIdFBO+1xcfFGqucCAcQ='; connect-src 'self'; form-action 'self'; upgrade-insecure-requests
